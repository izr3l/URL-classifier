{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "types": ["chrome"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["background/**/*.ts", "content/**/*.ts", "popup/**/*.tsx", "utils/**/*.ts"]
}
